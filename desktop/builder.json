{
  "appId": "com.onlytracker.morfi",
  "productName": "OnlyTracker Morfi",
  "asar": false,
  "directories": {
    "output": "dist-desktop"
  },
  "files": [
    "desktop/**",
    ".next/**",
    "prisma/schema.sqlite.prisma",
    "public/**",
    "package.json",
    "next.config.*",
    "node_modules/**",
    "!node_modules/.cache/**",
    "!node_modules/@prisma/engines/**/*.gz",
    "!node_modules/electron/**",
    "!node_modules/electron-builder/**"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
